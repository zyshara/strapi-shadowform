{
  "kind": "collectionType",
  "collectionName": "wedding_guest_profiles",
  "info": {
    "singularName": "wedding-guest-profile",
    "pluralName": "wedding-guest-profiles",
    "displayName": "WeddingGuestProfile"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "display_name": {
      "type": "string",
      "required": true
    },
    "profile_picture": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "wedding_guest_profile"
    },
    "address": {
      "type": "string",
      "required": true
    },
    "phone_number": {
      "type": "string",
      "required": true
    },
    "plus_one_allowed": {
      "type": "boolean",
      "required": true
    },
    "allowed_at_ceremony": {
      "type": "boolean",
      "required": true
    },
    "wedding_rsvp": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::wedding-rsvp.wedding-rsvp",
      "mappedBy": "wedding_guest_profile"
    },
    "wedding_invite_token": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::wedding-invite-token.wedding-invite-token",
      "inversedBy": "wedding_guest_profile"
    },
    "can_change_rsvp_until": {
      "type": "date",
      "required": true
    }
  }
}
