{
  "kind": "collectionType",
  "collectionName": "artists",
  "info": {
    "singularName": "artist",
    "pluralName": "artists",
    "displayName": "Artist"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "location": {
      "type": "string"
    },
    "primary_genre": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::genre.genre"
    },
    "genres": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::genre.genre"
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "blurb_biography": {
      "type": "string"
    },
    "biography": {
      "type": "text"
    },
    "social_links": {
      "type": "component",
      "component": "social-links.social-links",
      "repeatable": true
    },
    "artist_statistics": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::artists-statistics.artists-statistics",
      "inversedBy": "artist"
    },
    "management_page_card_links": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::link.link"
    },
    "instagram": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "spotify": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::link.link"
    },
    "songkick": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::artist.artist"
    }
  }
}
